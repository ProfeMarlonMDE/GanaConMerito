#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$ROOT"

echo "[post-commit] Proponiendo actualización de changelog..."
python3 scripts/update_changelog.py || true

echo "[post-commit] Detectando deuda técnica potencial..."
python3 scripts/detect_technical_debt.py || true

echo "[post-commit] OK"
