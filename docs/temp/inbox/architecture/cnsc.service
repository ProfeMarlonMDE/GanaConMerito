[Unit]
Description=GanaConMerito Next.js App
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/var/www/cnsc
ExecStart=/usr/bin/npm start
Restart=always
Environment=NODE_ENV=production
# Puerto por defecto para Next.js
Environment=PORT=3000

[Install]
WantedBy=multi-user.target
